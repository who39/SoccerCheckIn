@model SoccerCheckin.Web.Models.Family
@{
    ViewData["Title"] = "Create your family";
}

@if (TempData["Success"] is string s) { <div class="alert alert-success">@s</div> }
@if (TempData["Error"] is string e) { <div class="alert alert-danger">@e</div> }

<h1>Create your family</h1>
<p class="text-muted">A family is a group of people who can all check in for the same players. You'll be the family head and can add more members.</p>

<form asp-action="Create" method="post" class="mt-3" style="max-width:480px;">
    @Html.AntiForgeryToken()
    <div class="mb-3">
        <label class="form-label">Family name</label>
        <input name="name" class="form-control" placeholder="e.g. Smith" required maxlength="100" />
    </div>
    <button class="btn btn-primary">Create family</button>
</form>
