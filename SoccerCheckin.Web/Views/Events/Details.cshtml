@model SoccerCheckin.Web.Models.Event
@{
    ViewData["Title"] = Model.Title;
    var canManage = (bool)(ViewBag.CanManage ?? false);
    var myPlayers = (List<SoccerCheckin.Web.Models.Player>)(ViewBag.MyPlayers ?? new List<SoccerCheckin.Web.Models.Player>());
    var myAttendance = (Dictionary<int, bool>)(ViewBag.MyAttendance ?? new Dictionary<int, bool>());
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
    <div>
        <h1 class="mb-1">@Model.Title</h1>
        <p class="text-muted small mb-0">
            <i class="bi bi-trophy me-1"></i>
            <a asp-controller="Programs" asp-action="Details" asp-route-id="@Model.ProgramId">@Model.Program.Name</a>
        </p>
    </div>
    @if (canManage)
    {
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this event?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger">
                    <i class="bi bi-trash me-1"></i>Delete
                </button>
            </form>
        </div>
    }
</div>

<div class="card mb-3">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-2"><i class="bi bi-clock me-1"></i>When</dt>
            <dd class="col-sm-10 fw-semibold">@Model.StartUtc.ToLocalTime().ToString("dddd, MMMM d, yyyy · HH:mm")</dd>

            <dt class="col-sm-2"><i class="bi bi-geo-alt me-1"></i>Location</dt>
            <dd class="col-sm-10">
                @Model.Location
                @if (!string.IsNullOrWhiteSpace(Model.Location))
                {
                    var googleUrl = $"https://www.google.com/maps/search/?api=1&query={Uri.EscapeDataString(Model.Location)}";
                    <a href="@googleUrl" target="_blank" rel="noopener" class="ms-2 small">
                        <i class="bi bi-box-arrow-up-right"></i> Google Maps
                    </a>
                }
            </dd>

            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <dt class="col-sm-2"><i class="bi bi-card-text me-1"></i>Description</dt>
                <dd class="col-sm-10 mb-0">@Model.Description</dd>
            }
        </dl>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Location))
{
    var embedUrl = $"https://www.google.com/maps?q={Uri.EscapeDataString(Model.Location)}&output=embed";
    <div class="mb-4">
        <iframe
            src="@embedUrl"
            width="100%"
            height="350"
            style="border:0;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen>
        </iframe>
    </div>
}

<h4 class="sc-section"><i class="bi bi-check2-square text-success me-1"></i>My Check-ins</h4>
@if (!myPlayers.Any())
{
    <div class="alert alert-info d-flex align-items-center gap-2">
        <i class="bi bi-info-circle"></i>
        <span>You haven't added any players for this program yet.
            <a asp-controller="Players" asp-action="Create" asp-route-programId="@Model.ProgramId" class="fw-semibold">Add a player</a>.
        </span>
    </div>
}
else
{
    <table class="table">
        <thead><tr><th>Player</th><th>Status</th><th class="text-end">Actions</th></tr></thead>
        <tbody>
            @foreach (var p in myPlayers)
            {
                var hasValue = myAttendance.TryGetValue(p.Id, out var v);
                var status = hasValue ? (v ? "Attending" : "Not attending") : "Not set";
                var badgeClass = !hasValue ? "bg-light" : (v ? "bg-success" : "bg-secondary");
                var icon = !hasValue ? "bi-dash-circle" : (v ? "bi-check-circle-fill" : "bi-x-circle-fill");
                <tr>
                    <td class="fw-semibold"><i class="bi bi-person-circle text-muted me-1"></i>@p.Name</td>
                    <td><span class="badge @badgeClass"><i class="bi @icon me-1"></i>@status</span></td>
                    <td class="text-end">
                        <form asp-action="SetAttendance" asp-route-id="@Model.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="playerId" value="@p.Id" />
                            <input type="hidden" name="isAttending" value="true" />
                            <button type="submit" class="btn btn-sm btn-success"><i class="bi bi-check-lg me-1"></i>Check in</button>
                        </form>
                        <form asp-action="SetAttendance" asp-route-id="@Model.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="playerId" value="@p.Id" />
                            <input type="hidden" name="isAttending" value="false" />
                            <button type="submit" class="btn btn-sm btn-outline-secondary"><i class="bi bi-x-lg me-1"></i>Not attending</button>
                        </form>
                        @if (hasValue)
                        {
                            <form asp-action="ResetAttendance" asp-route-id="@Model.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="playerId" value="@p.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-warning" title="Clear vote"><i class="bi bi-arrow-counterclockwise me-1"></i>Reset</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<h4 class="sc-section"><i class="bi bi-people-fill text-success me-1"></i>All Check-ins</h4>
@{
    var attending = Model.Attendances.Where(a => a.IsAttending).OrderBy(a => a.Player.Name).ToList();
}
@if (!attending.Any())
{
    <div class="alert alert-info d-flex align-items-center gap-2">
        <i class="bi bi-info-circle"></i><span>No one has checked in yet.</span>
    </div>
}
else
{
    <ul class="list-group mb-3">
        @foreach (var a in attending)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <span><i class="bi bi-check-circle-fill text-success me-2"></i><strong>@a.Player.Name</strong></span>
                <span class="text-muted small">by @a.Player.OwnerUserSession.MicrosoftEmail</span>
            </li>
        }
    </ul>
}

<a class="btn btn-secondary" asp-controller="Programs" asp-action="Details" asp-route-id="@Model.ProgramId">
    <i class="bi bi-arrow-left me-1"></i>Back to Program
</a>
