@model string
@{
    ViewData["Title"] = "Invite Error";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body text-center p-4 p-md-5">
                <div class="mb-3" style="font-size:3rem;">⚠️</div>
                <h2 class="mb-2">Invite Unavailable</h2>
                <p class="text-muted mb-4">@Model</p>
                <a class="btn btn-primary" asp-controller="Programs" asp-action="Index">
                    <i class="bi bi-house me-1"></i>Go to Programs
                </a>
            </div>
        </div>
    </div>
</div>
