@model IEnumerable<SoccerCheckin.Web.Models.Program>
@using SoccerCheckin.Web.Models
@{
    ViewData["Title"] = "Programs";
    var isAdmin = (bool)(ViewBag.IsAdmin ?? false);
    var managedProgramIds = (HashSet<int>)(ViewBag.ManagedProgramIds ?? new HashSet<int>());
}

<section class="sc-hero">
    <h1 class="display-6 mb-2">Soccer Check-in</h1>
    <p class="lead mb-0">Manage soccer programs, schedule events, and check players in.</p>
    @if (!isAdmin && !Model.Any())
    {
        <p class="text-muted small mt-2 mb-0">No programs yet — create your own, or ask a coach to share an invite link with you.</p>
    }
</section>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="h4 mb-0 sc-section">
        <i class="bi bi-trophy text-success me-1"></i>Programs
    </h2>
    <a class="btn btn-primary" asp-action="Create">
        <i class="bi bi-plus-lg me-1"></i>New Program
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info d-flex align-items-center gap-2">
        <i class="bi bi-info-circle"></i>
        <span>You don't have any programs yet. Click <strong>New Program</strong> to create one.</span>
    </div>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Updated</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                var canManage = isAdmin || managedProgramIds.Contains(p.Id);
                <tr>
                    <td>
                        <a class="fw-semibold" asp-action="Details" asp-route-id="@p.Id">@p.Name</a>
                    </td>
                    <td class="text-muted">@p.Description</td>
                    <td><span class="text-muted small">@p.UpdatedAtUtc.ToString("yyyy-MM-dd")</span></td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@p.Id">
                            <i class="bi bi-eye"></i> View
                        </a>
                        @if (canManage)
                        {
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@p.Id">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a class="btn btn-sm btn-outline-info" asp-action="Members" asp-route-id="@p.Id">
                                <i class="bi bi-people"></i> Members
                            </a>
                            <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this program?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
