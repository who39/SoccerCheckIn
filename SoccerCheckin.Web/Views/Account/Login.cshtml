@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6 col-lg-5">
        <div class="card">
            <div class="card-body p-4 p-md-5 text-center">
                <div class="mb-3" style="font-size:3rem;">⚽</div>
                <h2 class="card-title mb-2">Welcome to Soccer Check-in</h2>
                <p class="text-muted mb-4">Sign in with your Microsoft account to continue</p>

                <form asp-action="MicrosoftLogin" method="post" class="mb-3">
                    <button type="submit" class="btn btn-primary btn-lg w-100 d-flex align-items-center justify-content-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 23 23" aria-hidden="true">
                            <rect x="1" y="1"  width="10" height="10" fill="#f25022"/>
                            <rect x="12" y="1" width="10" height="10" fill="#7fba00"/>
                            <rect x="1" y="12" width="10" height="10" fill="#00a4ef"/>
                            <rect x="12" y="12" width="10" height="10" fill="#ffb900"/>
                        </svg>
                        <span>Sign in with Microsoft</span>
                    </button>
                </form>

                <hr class="my-4" />

                <p class="text-muted small mb-0">
                    You can sign in with a personal Microsoft account (hotmail.com, outlook.com, live.com).
                    Your profile is only used to identify you within this app.
                </p>
            </div>
        </div>
    </div>
</div>
