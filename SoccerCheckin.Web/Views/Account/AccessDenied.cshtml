@{
    ViewData["Title"] = "Access Denied";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body text-center p-4 p-md-5">
                <div class="mb-3" style="font-size:3rem;">🚫</div>
                <h2 class="mb-2">Access Denied</h2>
                <p class="text-muted mb-4">
                    You're signed in, but you don't have permission to view that page.
                </p>
                <a class="btn btn-primary" asp-controller="Programs" asp-action="Index">
                    <i class="bi bi-house me-1"></i>Go to Programs
                </a>
                <form asp-controller="Account" asp-action="LogOut" method="post" class="d-inline ms-2">
                    <button type="submit" class="btn btn-outline-secondary">
                        <i class="bi bi-box-arrow-right me-1"></i>Sign out
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
