# Normalize text files in Git and keep LF in source files
* text=auto

# Keep Visual Studio solution files in CRLF
*.sln text eol=crlf

# Source and web files use LF
*.cs text eol=lf
*.cshtml text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
